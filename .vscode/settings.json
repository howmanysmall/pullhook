{
	"[github-actions-workflow]": {
		"editor.defaultFormatter": "redhat.vscode-yaml",
		"editor.formatOnSave": true,
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.formatOnSave": true,
		"editor.quickSuggestions": {
			"strings": true,
		},
		"editor.suggest.insertMode": "replace",
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.formatOnSave": true,
		"editor.quickSuggestions": {
			"strings": true,
		},
		"editor.suggest.insertMode": "replace",
	},
	"[markdown]": {
		"cSpell.advanced.feature.useReferenceProviderRemove": "/^#+\\s/",
		"cSpell.advanced.feature.useReferenceProviderWithRename": true,
		"cSpell.fixSpellingWithRenameProvider": true,
		"diffEditor.ignoreTrimWhitespace": false,
		"editor.defaultFormatter": "rvben.rumdl",
		"editor.quickSuggestions": {
			"comments": "off",
			"other": "off",
			"strings": "off",
		},
		"editor.unicodeHighlight.ambiguousCharacters": false,
		"editor.unicodeHighlight.invisibleCharacters": false,
		"editor.wordWrap": "on",
	},
	"[rust]": {
		"editor.defaultFormatter": "rust-lang.rust-analyzer",
	},
	"[snippets]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.formatOnSave": true,
		"editor.quickSuggestions": {
			"strings": true,
		},
		"editor.suggest.insertMode": "replace",
	},
	"[toml]": {
		"editor.defaultFormatter": "tombi-toml.tombi",
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome",
	},
	"[yaml]": {
		"editor.defaultFormatter": "redhat.vscode-yaml",
		"editor.formatOnSave": true,
	},

	"cSpell.words": ["lefthook", "gitleaks"],

	"editor.acceptSuggestionOnCommitCharacter": true,
	"editor.acceptSuggestionOnEnter": "on",
	"editor.codeActionsOnSave": {
		"source.addMissingImports": "explicit",
		"source.biome": "explicit",
		"source.fixAll.rumdl": "explicit",
		"source.fixAll.shellcheck": "explicit",
		"source.organizeImports": "explicit",
		"source.removeUnusedImports": "explicit",
	},
	"editor.formatOnSave": true,
	"editor.quickSuggestions": {
		"comments": false,
		"other": true,
		"strings": true,
	},
	"editor.suggest.snippetsPreventQuickSuggestions": false,

	"files.eol": "\n",
}
