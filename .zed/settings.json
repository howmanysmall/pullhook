{
	"auto_indent": true,
	"code_actions_on_format": {
		"source.fixAll": true,
		"source.organizeImports": true
	},
	"disable_ai": false,
	"edit_predictions": {
		"codestral": {},
		"copilot": {},
		"enabled_in_text_threads": false,
		"mode": "eager"
	},
	"ensure_final_newline_on_save": true,
	"file_types": {
		"JSONC": [
			"tsconfig.json",
			"jsconfig.json",
			".vscode/*.json",
			".oxfmtrc.json",
			".oxlintrc.json",
			"*.code-workspace",
			"tsconfig*.json",
			"*.code-snippets"
		],
		"Shell Script": ["zsh", "zshrc", "zprofile", "zshenv", "bashrc", "bash_profile"],
		"TOML": ["toml"],
		"YAML": ["*.yml", "*.yaml", ".github/workflows/*.yml", ".github/workflows/*.yaml"]
	},
	"format_on_save": "on",
	"hard_tabs": true,
	"indent_guides": {
		"active_line_width": 1,
		"background_coloring": "disabled",
		"coloring": "indent_aware",
		"enabled": true,
		"line_width": 1
	},
	"inlay_hints": {
		"edit_debounce_ms": 700,
		"enabled": true,
		"scroll_debounce_ms": 50,
		"show_other_hints": true,
		"show_parameter_hints": true,
		"show_type_hints": true
	},
	"languages": {
		"JSON": {
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			},
			"format_on_save": "on",
			"formatter": {
				"language_server": { "name": "biome" }
			},
			"hard_tabs": true,
			"language_servers": ["!oxfmt", "biome", "..."],
			"tab_size": 4
		},
		"JSONC": {
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			},
			"format_on_save": "on",
			"formatter": {
				"language_server": { "name": "biome" }
			},
			"hard_tabs": true,
			"language_servers": ["!oxfmt", "biome", "..."],
			"tab_size": 4
		},
		"Markdown": {
			"format_on_save": "on",
			"formatter": [{ "language_server": { "name": "rumdl" } }],
			"hard_tabs": true,
			"language_servers": ["!marksman", "!markdownlint", "rumdl", "..."],
			"show_whitespaces": "none",
			"soft_wrap": "editor_width",
			"tab_size": 4
		},
		"TOML": {
			"format_on_save": "on",
			"formatter": "language_server",
			"hard_tabs": true,
			"tab_size": 4
		},
		"YAML": {
			"formatter": "language_server",
			"language_servers": ["..."]
		}
	},
	"lsp": {
		"biome": {
			"binary": {
				"arguments": ["x", "--bun", "biome", "lsp-proxy"],
				"path": "bun"
			}
		},
		"rust-analyzer": {
			"enable_lsp_tasks": true,
			"initialization_options": {
				"cargo": {
					"allTargets": true,
					"buildScripts": {
						"enable": true
					},
					"features": "all",
					"targetDir": true
				},
				"check": {
					"allTargets": true,
					"command": "clippy",
					"features": "all",
					"workspace": true
				},
				"checkOnSave": true,
				"diagnostics": {
					"experimental": {
						"enable": true
					},
					"styleLints": {
						"enable": true
					}
				},
				"inlayHints": {
					"bindingModeHints": {
						"enable": true
					},
					"chainingHints": {
						"enable": true
					},
					"closureCaptureHints": {
						"enable": true
					},
					"closureReturnTypeHints": {
						"enable": "always"
					},
					"genericParameterHints": {
						"const": {
							"enable": true
						},
						"lifetime": {
							"enable": true
						},
						"type": {
							"enable": true
						}
					},
					"lifetimeElisionHints": {
						"enable": "skip_trivial",
						"useParameterNames": true
					},
					"maxLength": null,
					"parameterHints": {
						"enable": true,
						"missingArguments": {
							"enable": true
						}
					},
					"typeHints": {
						"enable": true
					}
				},
				"procMacro": {
					"enable": true
				}
			}
		},
		"yaml-language-server": {
			"settings": {
				"yaml": {
					"format": {
						"singleQuote": true
					},
					"keyOrdering": true,
					"schemas": {
						"./schemas/kubernetes.yaml": "k8s/**/*.yaml",
						"~/global-schemas/docker-compose.yaml": "docker-compose*.yml",
						"https://getcomposer.org/schema.json": ["/*"]
					}
				}
			}
		}
	},
	"remove_trailing_whitespace_on_save": true,
	"show_completions_on_input": true,
	"show_edit_predictions": true,
	"tab_size": 4,
	"terminal": {
		"working_directory": "current_project_directory"
	},
	"use_on_type_format": true
}
