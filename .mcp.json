{
	"mcpServers": {
		"context7": {
			"headers": { "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}" },
			"type": "http",
			"url": "https://mcp.context7.com/mcp"
		},
		"gh-grep": {
			"type": "http",
			"url": "https://mcp.grep.app"
		},
		"package-registry": {
			"args": ["x", "--bun", "package-registry-mcp"],
			"command": "bun",
			"type": "stdio"
		}
	}
}
