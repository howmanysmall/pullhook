{
	"$schema": "https://opencode.ai/config.json",
	"agent": {
		"ask": {
			"model": "openai/gpt-5.3-codex",
			"temperature": 0,
		},
		"ask/codex-5.3": {
			"description": "Just regular Codex 5.3.",
			"hidden": false,
			"mode": "subagent",
			"model": "openai/gpt-5.3-codex",
		},
		"ask/gemini-3-pro": {
			"description": "Just regular Gemini 3 Pro.",
			"hidden": false,
			"mode": "subagent",
			"model": "github-copilot/gemini-3-pro-preview",
		},
		"ask/gemini-3.1-pro": {
			"description": "Just regular Gemini 3.1 Pro.",
			"hidden": false,
			"mode": "subagent",
			"model": "github-copilot/gemini-3.1-pro-preview",
		},
		"ask/glm-5": {
			"description": "Just regular GLM 5.",
			"hidden": false,
			"mode": "subagent",
			"model": "zai-coding-plan/glm-5",
		},
		"ask/kimi-k2.5": {
			"color": "#8B5CF6",
			"description": "Just regular Kimi K2.5.",
			"hidden": false,
			"mode": "subagent",
			"model": "kimi-for-coding/k2p5",
		},
		"ask/opus-4.6": {
			"color": "#6B5CE7",
			"description": "Just regular Opus 4.6.",
			"hidden": false,
			"mode": "subagent",
			"model": "github-copilot/claude-opus-4.6",
		},
		"build": {
			"description": "Used after creating a plan or just whenever.",
			"mode": "all",
			"model": "openai/gpt-5.3-codex",
			"permission": {
				"bash": {
					"*": "ask",
					"bat *": "allow",
					"cat *": "allow",
					"cd *": "allow",
					"delta *": "allow",
					"diff *": "allow",
					"du *": "allow",
					"dust *": "allow",
					"exa *": "allow",
					"fd *": "allow",
					"find *": "allow",
					"git diff*": "allow",
					"git status*": "allow",
					"grep *": "allow",
					"ls *": "allow",
					"lsd *": "allow",
					"peekaboo *": "allow",
					"rg *": "allow",
					"sd *": "allow",
					"sed *": "allow",
				},
				"codesearch": "allow",
				"doom_loop": "ask",
				"edit": "allow",
				"external_directory": "ask",
				"glob": "allow",
				"grep": "allow",
				"list": "allow",
				"lsp": "allow",
				"question": "allow",
				"read": "allow",
				"skill": "allow",
				"task": "allow",
				"todoread": "allow",
				"todowrite": "allow",
				"webfetch": "allow",
				"websearch": "allow",
			},
		},
		"plan": {
			"description": "Used to generate a plan.",
			"model": "openai/gpt-5.3-codex",
			"permission": {
				"bash": {
					"*": "ask",
					"bat *": "allow",
					"cat *": "allow",
					"cd *": "allow",
					"delta *": "allow",
					"diff *": "allow",
					"du *": "allow",
					"dust *": "allow",
					"exa *": "allow",
					"fd *": "allow",
					"find *": "allow",
					"git diff*": "allow",
					"git status*": "allow",
					"grep *": "allow",
					"ls *": "allow",
					"lsd *": "allow",
					"rg *": "allow",
					"sd *": "allow",
					"sed *": "allow",
				},
				"codesearch": "allow",
				"doom_loop": "ask",
				"edit": "deny",
				"external_directory": "ask",
				"glob": "allow",
				"grep": "allow",
				"list": "allow",
				"lsp": "allow",
				"question": "allow",
				"read": "allow",
				"task": "allow",
				"todoread": "allow",
				"todowrite": "allow",
				"webfetch": "ask",
				"websearch": "allow",
			},
		},
	},
	"experimental": {
		"batch_tool": true,
	},
	"formatter": {},
	"instructions": ["./AGENTS.md"],
	"layout": "stretch",
	"lsp": {
		"rumdl": {
			"command": ["rumdl", "server"],
			"disabled": false,
			"extensions": [
				".md",
				".markdown",
				".mdown",
				".mkdn",
				".mkd",
				".mdwn",
				".mdtxt",
				".mdtext",
				".text",
				".Rmd",
			],
		},
		"tombi": {
			"command": ["tombi", "lsp"],
			"disabled": false,
			"extensions": [".toml"],
		},
	},
	"mcp": {
		"context7": {
			"enabled": true,
			"headers": { "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}" },
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
		},
		"gh-grep": {
			"enabled": true,
			"type": "remote",
			"url": "https://mcp.grep.app",
		},
		"github": {
			"command": ["bun", "x", "--bun", "@modelcontextprotocol/server-github"],
			"enabled": false,
			"environment": { "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}" },
			"type": "local",
		},
		"package-registry": {
			"command": ["bun", "x", "--bun", "package-registry-mcp"],
			"enabled": true,
			"type": "local",
		},
	},
	"permission": {
		"bash": {
			"*": "ask",
			"bat *": "allow",
			"cat *": "allow",
			"cd *": "allow",
			"delta *": "allow",
			"diff *": "allow",
			"du *": "allow",
			"dust *": "allow",
			"exa *": "allow",
			"fd *": "allow",
			"find *": "allow",
			"grep *": "allow",
			"ls *": "allow",
			"lsd *": "allow",
			"rg *": "allow",
			"sd *": "allow",
			"sed *": "allow",
		},
		"doom_loop": "ask",
		"edit": "ask",
		"external_directory": "ask",
		"skill": "ask",
		"webfetch": "ask",
	},
	"plugin": ["opencode-wakatime"],
	"share": "manual",
	"username": "pullhook",
}
